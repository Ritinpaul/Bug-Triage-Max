# ── Backend ─────────────────────────────────────────────────────────────
APP_ID=                         # Application ID (used for JWT audience)
APP_SECRET=                     # Application secret (used for JWT signing)

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction" pooler URL for serverless, or "Session" for long-running
DATABASE_URL=                   # postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Supabase (Direct Client Access) ─────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=                   # https://[your-project-ref].supabase.co
SUPABASE_ANON_KEY=              # eyJ... (safe to expose in browser)
SUPABASE_SERVICE_ROLE_KEY=      # eyJ... (⚠️ NEVER expose in browser — server-side only)

# ── Frontend (exposed to browser via Vite) ───────────────────────────────
VITE_KIMI_AUTH_URL=             # Kimi OAuth server URL (e.g. https://auth.kimi.com)
VITE_APP_ID=                    # OAuth application ID

# ── Backend (Auth) ───────────────────────────────────────────────────────
KIMI_AUTH_URL=                  # Kimi OAuth server URL (backend)
KIMI_OPEN_URL=                  # Kimi Open Platform URL (e.g. https://open.kimi.com)

# ── Admin Role ───────────────────────────────────────────────────────────
OWNER_UNION_ID=                 # Union ID of the app creator; gets role "admin" on first login

# ── AI (Google Gemini) ───────────────────────────────────────────────────
# Get from: https://aistudio.google.com → Get API Key
# Powers: Parser Agent, Reproduction Agent, Vector Embeddings, Release Note Generation
GEMINI_API_KEY=

# ── GitHub ───────────────────────────────────────────────────────────────
# Get from: GitHub → Settings → Developer Settings → Personal Access Tokens → Fine-grained
# Required scopes: Contents (read/write), Issues (read/write), Metadata (read)
GITHUB_PAT=                     # ghp_xxxxxxxxxxxx
GITHUB_REPO_OWNER=              # e.g. your-org or your-username
GITHUB_REPO_NAME=               # e.g. your-repo

# ── Slack ────────────────────────────────────────────────────────────────
# Slack integration (optional)
SLACK_SIGNING_SECRET=""
SLACK_BOT_TOKEN="xoxb-..."

# Stripe Billing (optional)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email IMAP ───────────────────────────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
EMAIL_IMAP_HOST=                # e.g. imap.gmail.com
EMAIL_IMAP_PORT=993             # 993 for TLS (recommended), 143 for STARTTLS
EMAIL_IMAP_USER=                # e.g. bugs@yourcompany.com
EMAIL_IMAP_PASSWORD=            # App-specific password (NOT your main Gmail password)
